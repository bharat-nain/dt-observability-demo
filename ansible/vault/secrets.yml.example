---
# Copy this to secrets.yml and encrypt with:
#   ansible-vault encrypt ansible/vault/secrets.yml
#
# To edit later:
#   ansible-vault edit ansible/vault/secrets.yml

# PaaS / installer token -- used ONLY for downloading the OneAgent installer
# Get from: Deploy Dynatrace -> Start installation -> Linux (token in the wget URL)
dt_paas_token: "dt0c01.YOUR_PAAS_TOKEN_HERE"

# API token -- used for Config API: dashboards, SLOs, alerts, management zones
# Create at: Settings -> Access Tokens
# Required scopes: Read/Write configuration, Read metrics, Read entities,
#                  Read/Write SLO, Read/Write settings
dt_api_token: "dt0c01.YOUR_API_TOKEN_HERE"
