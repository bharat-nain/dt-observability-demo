      },
      "davis": {
        "enabled": false,
        "davisVisualization": { "isAvailable": true }
      }
    },
    "8": {
      "title": "GC Suspension Time — Heap Pressure Indicator",
      "type": "data",
      "query": "timeseries gc_time = max(jvm.gc.pause_time), by:{dt.entity.process_group_instance}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "hidden": false }
        },
        "thresholds": []
