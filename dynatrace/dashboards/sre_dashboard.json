    "7": {
      "title": "JVM Heap Used — Soak Test Indicator (should stay flat)",
      "type": "data",
      "query": "timeseries heap_used = avg(jvm.memory.used), filter:{jvm.memory.type == \"heap\"}, by:{dt.entity.process_group_instance}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "hidden": false }
        },
        "thresholds": []
      },
      "querySettings": {
        "maxResultRecords": 1000,
        "defaultScanLimitGbytes": 500,
